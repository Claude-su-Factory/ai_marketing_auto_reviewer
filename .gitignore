# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Environment (never commit real secrets)
.env
.env.*
!.env.*.example

# Config (secrets)
config.toml
!config.example.toml

# Runtime data (user-specific, includes scraped content, generated media, campaigns)
data/
logs/

# Generated media
*.jpg
*.jpeg
*.png
*.mp4
*.mov
*.webm

# Databases
*.db
*.db-journal
*.sqlite
*.sqlite3
packages/server/tmp/

# launchd / local worker (installed plist lives at ~/Library/LaunchAgents/, never in repo)
# The template scripts/com.adai.worker.plist no longer carries secret placeholders (worker reads config.toml from cwd) — safe to commit.

# Personal helper scripts (contain secrets or machine-specific paths)
scripts/*.local.sh

# Test / coverage
coverage/
.nyc_output/

# Superpowers / Claude session artifacts
.superpowers/
.claude/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
