# =============================================================================
# Service 모드 — Usage API Server를 호스팅해서 라이선스를 판매할 때
# =============================================================================
# 사용처:
#   - server/index.ts (Express + AI proxy routes + Stripe webhook)
#   - server/scheduler.ts (운영자 본인 계정 기준 자기학습 루프)
#
# 고객은 AD_AI_MODE=customer + AD_AI_LICENSE_KEY 만 세팅하고 이 서버에 붙는다.
# 따라서 이 파일에는 서버가 고객 대신 호출하는 AI 키들과, 빌링(Stripe)에
# 필요한 키들을 둔다.
#
# Meta 블록은 "서비스 운영자가 자체 광고 계정을 운영해 scheduler로 Winner DB
# 를 축적하고 싶을 때"만 채운다. 비워두면 server/scheduler 의 improvementCycle
# 은 그대로 뜨지만 실 데이터가 없어 no-op이 된다.
#
# 복사: `cp .env.service.example .env`
# =============================================================================


# --- AI 모델 API 키 (필수) ----------------------------------------
# 고객이 AI proxy 라우트(/ai/copy, /ai/image, /ai/video, /ai/parse, /ai/analyze)
# 를 호출할 때 서버가 대신 이 키로 모델을 호출한다.

# Anthropic Claude — /ai/copy, /ai/analyze
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google AI Studio — /ai/image, /ai/video, /ai/parse
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Voyage AI — server/scheduler.ts 부트 시점에 체크됨. 없으면 throw.
# Winner DB qualify 단계에서 embedding 호출에 사용.
VOYAGE_API_KEY=your-voyage-api-key-here


# --- Server 설정 (필수) ------------------------------------------
SERVER_PORT=3000

# Stripe 체크아웃 redirect, 고객에게 노출되는 base URL. 프로덕션에서는 도메인.
# 비어있으면 http://localhost:$SERVER_PORT 로 대체된다.
SERVER_BASE_URL=https://your-domain.example.com


# --- Stripe 빌링 (필수) ------------------------------------------
# 둘 중 하나라도 비어있으면 webhook 라우트 비활성 → 빌링 기능 off.
# 발급: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...


# --- Meta (선택 — 운영자 자체 광고 계정이 있을 때만) ---------------
# server/scheduler.ts 의 자기학습 루프가 `collectDailyReports`를 돌린다.
# 비워두면 scheduler는 뜨지만 실 Meta 데이터가 없어 no-op이 된다.
# 서비스 운영자가 직접 광고 캠페인을 운영해 Winner DB를 축적할 때만 설정.
#
# ─ META_APP_ID / META_APP_SECRET ───────────────────────────────────
# https://developers.facebook.com/apps → 내 앱 → 만들기 → Business 타입 선택
# 생성 후 좌측 "앱 설정 → 기본 설정" 에서:
#   - 앱 ID          → META_APP_ID
#   - 앱 시크릿 코드 → META_APP_SECRET (표시 클릭)
META_APP_ID=
META_APP_SECRET=
#
# ─ META_ACCESS_TOKEN ───────────────────────────────────────────────
# 장기 자동화용 System User 토큰 발급 권장 (단기 토큰은 1~2시간 만료).
# 1. https://business.facebook.com → 비즈니스 설정
# 2. 사용자 → 시스템 사용자 → 추가
# 3. 자산 할당: 광고 계정·페이지, 권한 "관리"
# 4. 토큰 생성 → 앱 선택 → 아래 scope 모두 체크 → 토큰 복사
# 필요한 scope:
#   ads_management, ads_read, pages_read_engagement,
#   pages_manage_ads, instagram_basic, business_management
META_ACCESS_TOKEN=
#
# ─ META_AD_ACCOUNT_ID ──────────────────────────────────────────────
# https://business.facebook.com → 비즈니스 설정 → 계정 → 광고 계정
# 형식: act_1234567890 (숫자 앞에 반드시 act_ 접두어 필요)
# 확인용: curl "https://graph.facebook.com/v19.0/me/adaccounts?access_token={TOKEN}"
META_AD_ACCOUNT_ID=
#
# ─ META_PAGE_ID ────────────────────────────────────────────────────
# Facebook 페이지 → 정보 탭 맨 아래 "페이지 ID" (순수 숫자)
# 확인용: curl "https://graph.facebook.com/v19.0/me/accounts?access_token={TOKEN}"
META_PAGE_ID=
#
# ─ META_INSTAGRAM_ACTOR_ID ─────────────────────────────────────────
# 페이지에 Instagram 비즈니스 계정 연결 후 Graph API로 조회:
#   curl "https://graph.facebook.com/v19.0/{PAGE_ID}?fields=instagram_business_account&access_token={TOKEN}"
# 응답의 instagram_business_account.id 값
# 연결 안 돼 있으면: 페이지 설정 → Instagram → 계정 연결 먼저
META_INSTAGRAM_ACTOR_ID=


# --- 광고 기본 설정 (선택, 기본값 있음) -----------------------------
# Meta 블록을 채웠을 때만 의미 있음.
AD_DAILY_BUDGET_KRW=10000
AD_TARGET_AGE_MIN=20
AD_TARGET_AGE_MAX=45
AD_DURATION_DAYS=14
CTR_IMPROVEMENT_THRESHOLD=1.5
AD_PLATFORMS=meta
