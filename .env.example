# Voyage AI — https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=your-voyage-api-key-here

# Meta
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_INSTAGRAM_ACTOR_ID=

# 광고 기본 설정 (선택, 오버라이드 가능)
