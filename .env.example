AD_TARGET_AGE_MIN=20
AD_TARGET_AGE_MAX=45
AD_DURATION_DAYS=14
CTR_IMPROVEMENT_THRESHOLD=1.5

# CLI 모드 설정 (owner | customer)
AD_AI_MODE=owner
AD_AI_LICENSE_KEY=
AD_AI_SERVER_URL=http://localhost:3000

# Server 전용
SERVER_PORT=3000
SERVER_BASE_URL=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
